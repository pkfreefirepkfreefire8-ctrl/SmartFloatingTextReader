<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fab_container"
    android:layout_width="60dp"
    android:layout_height="60dp"
    android:padding="4dp">

    <!-- Pulse ring -->
    <View
        android:id="@+id/fab_pulse"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:background="@drawable/pulse_circle"
        android:visibility="gone" />

    <!-- Main FAB background -->
    <View
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:background="@drawable/fab_background"
        android:elevation="8dp" />

    <!-- Icon -->
    <ImageView
        android:id="@+id/fab_icon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_play"
        android:contentDescription="Reading control"
        android:elevation="10dp" />

    <!-- State indicator text -->
    <TextView
        android:id="@+id/fab_state_text"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="2dp"
        android:text="▶"
        android:textSize="8sp"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:background="@drawable/state_indicator_bg"
        android:elevation="11dp" />

</FrameLayout>
